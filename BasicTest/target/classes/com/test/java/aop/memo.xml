<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:aop="http://www.springframework.org/schema/aop"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-4.3.xsd">

	<!-- memo.xml > 스프링 컨테이너 -->
	<!--  
		스프링의 관리 대상이 되려면 > 스프링 빈이 되어야 한다.		
	-->
	
	<!-- 주 업무 객체 역할 -->
	<bean class="com.test.java.aop.MemoImpl" id="memo"></bean>
	
	<!-- 보조 업무 객체 역할 -->
	<bean class="com.test.java.aop.Logger" id="logger"></bean>
	
	<!-- 
		AOP
		1. 주 업무 객체 지정
		2. 보조 업무 객체 지정 
	-->
	<aop:config>
		
		<!-- 보조 업무 객체 역할 부여(Role) -->
		<aop:aspect ref="logger">
			
			<!-- 
				보조 업무 객체가 주업무들 중 어느 업무에 개입
				- PointCut 지정하기
				
				PointCut
				- 주업무(특정) 클래스의 메서드
				- MemoImpl 클래스의 add 메서드
				- MemoImpl 클래스의 read 메서드
				
				PointCut Expression
				- 어떤 패키지 + 어떤 클래스 + 어떤 메서드
				- AspectJ 표현식
				
				AspectJ 표현식
				- execution() 지시자
					- execution([접근지정자] 반환형 [패키지.클래스].메서드(인자))
					- execution(public void com.test.java.aop.MemoImpl.add(String))
						- '*'  : 와일드카드(접근지정자, 반환형, 패키지, 클래스, 메서드)
						- '..' : 와일드카드(인수)
				
				- within() 지시자				
			 -->
			 <aop:pointcut expression="execution(public void com.test.java.aop.MemoImpl.addMemo(String))" id="p1"/>
			 <aop:pointcut expression="execution(public String com.test.java.aop.MemoImpl.readMemo(String))" id="p2"/>
			 <aop:pointcut expression="execution(public boolean com.test.java.aop.MemoImpl.edit(String, String))" id="p3"/>
			 <aop:pointcut expression="execution(public boolean com.test.java.aop.MemoImpl.del(String))" id="p4"/>
			 
			 
			 <!-- 와일드카드 사용 -->
			 <aop:pointcut expression="execution(public * com.test.java.aop.MemoImpl.*(..))" id="p5"/>
			 
			 <aop:pointcut expression="execution(public boolean com.test.java.aop.MemoImpl.*(..))" id="p6"/>
			 <aop:pointcut expression="execution(public * com.test.java.aop.MemoImpl.*Memo(..))" id="p7"/>
			 <aop:pointcut expression="execution(* addMemo(..))" id="p8"/>
			 
			 <aop:pointcut expression="execution(public void com.test.java.aop.MemoImpl.addMemo(String)) || execution(public boolean com.test.java.aop.MemoImpl.edit(String, String))" id="p9"/>
			 
			 <!--
			  
			 	어떤 보조 업무 + 어느 시점에 개입
			 	
			 	PointCut + 보조업무객체.메서드() = 결합 > 위빙(Weaving)
			 	
			 	위빙 시점(주업무 & 보조업무의 순서)
			 	1. Before Advice
			 	2. After Advice: 주업무 > 보조업무
			 	3. Around Advice
			 	
			 	4. After-returning Advice
			 	
			 	5. After-throwing Advice
			 				 	
			 -->
			  
			<!-- 주업무(pointcut-ref="p1") + 보조업무(method="log") -->
			<!--  
			<aop:after method="log" pointcut-ref="p1" />
			<aop:after method="log" pointcut-ref="p2" />
			<aop:after method="log" pointcut-ref="p3" />
			<aop:after method="log" pointcut-ref="p4" /> 
			-->
			 
			<!-- 1:4 -->
			<!-- <aop:after method="log" pointcut-ref="p5" /> -->
			<!-- <aop:before method="test" pointcut-ref="p6" /> -->
			<!-- <aop:after method="log" pointcut-ref="p7" /> -->
			<!-- <aop:after method="log" pointcut-ref="p8" /> -->
			<!-- <aop:after method="log" pointcut-ref="p9" /> 비권장 -->
			
			<!-- add() + log() -->
			<!-- 주업무 -> 보조업무 -->
			<!-- <aop:after method="log" pointcut-ref="p1"></aop:after> -->
			
			<!-- 보조업무 -> 주업무 -->
			<!-- <aop:before method="log" pointcut-ref="p1" />
			<aop:before method="test" pointcut-ref="p1" /> -->
			
			<!-- 보조업무 > 주업무 > 보조업무 -->
			<!-- <aop:around method="time" pointcut-ref="p1" />
			<aop:around method="time" pointcut-ref="p4" /> -->
			
			<!-- 주업무 > (반환값 전달) > 보조업무 -->
			<!-- <aop:after-returning method="checkVaild" pointcut-ref="p4" returning="result" />
			<aop:after-returning method="checkVaild" pointcut-ref="p2" returning="result" /> -->
			
			<!-- 주업무 > (반환값 전달) > 보조업무 -->
			<aop:after-throwing method="logException" pointcut-ref="p2" throwing="e" />
			
		</aop:aspect>
		
	</aop:config>
	
</beans>
